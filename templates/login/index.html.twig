{% extends 'base.html.twig' %}
{% block body %}
    <form method="post" action="{{ path('app_login') }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        
        <div class="d-flex flex-column w-50 mx-auto">
            <h3 class="text-end">Connexion a l'espace d'administration</h3>
            
            {% if error %}
            <div>{{ error.messageKey|trans(error.messageData, "security") }}</div>
            {% endif %}
        
            <div class="d-flex gap-4 mt-4">
                <label class="flex-grow-1 text-end w-25" for="username">
                    Login / nom d'utilisateur
                </label>
                <input class="flex-grow-1 form-control w-auto" type="text" id="username" 
                       name="_username" value="{{ last_username }}" required 
                       autofocus />
            </div>
        
            <div class="d-flex gap-4 mt-2">
                <label class="flex-grow-1 text-end w-25" for="password">Mot de passe</label>
                <input class="flex-grow-1 form-control w-auto" type="password" id="password" 
                       name="_password" required />
            </div>
        
            <div class="text-end mt-4">
                <a class="btn btn-md btn-primary" href="{{ path('accueil') }}">retour a l'accueil</a>
                <button class="btn btn-md btn-primary" type="submit">
                    se connecter
                </button>
            </div>
        </div>
    </form>
{% endblock %}
